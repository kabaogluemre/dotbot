# User preferences (local settings)
profile/

# Runtime state and signals
.control/

# Chrome dev profile (isolated browser for dev dashboard)
.chrome-dev/

# Session run logs (autonomous execution history)
state/sessions/runs/

# Development process tracking
.dev-pids.json

# Ephemeral task state JSONs (rewritten each run — samples/ stay tracked)
workspace/tasks/**/*.json
!workspace/tasks/samples/**

# Interview artifacts (per-run ephemeral — samples/ stay tracked)
workspace/product/interview-answers.json
workspace/decisions/**/*.json
!workspace/decisions/samples/**
